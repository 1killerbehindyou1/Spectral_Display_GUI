	cd chapter5-listproperties\ && ( if not exist Makefile $(QMAKE) -o Makefile "C:\Users\mplesniak\Desktop\1. Mentoring_QT_project\9.example\extending-qml\chapter5-listproperties\chapter5-listproperties.pro" -spec win32-g++ "CONFIG+=debug" "CONFIG+=qml_debug" "CONFIG-=qtquickcompiler" ) && $(MAKE) -f Makefile check
